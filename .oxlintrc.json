{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-console": "error",
    "no-unused-vars": "error",
    "typescript/no-explicit-any": "error"
  },
  "env": {
    "builtin": true
  }
}
